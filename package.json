{
  "name": "solva-hris",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-tenant HRIS and Kenya-ready payroll platform for Solva HR Consultancy.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @solva/web",
    "dev:api": "npm run dev --workspace @solva/api",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspace @solva/shared",
    "typecheck": "npm run typecheck --workspaces",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:leave": "tsx prisma/seed-leave.ts",
    "db:seed:payroll": "tsx prisma/seed-payroll.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "prisma": "^5.22.0"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "engines": {
    "node": ">=20"
  }
}
