generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum EmploymentStatus {
  ACTIVE
  PROBATION
  SUSPENDED
  ON_LEAVE
  TERMINATED
  ARCHIVED
}

enum PayrollRunStatus {
  DRAFT
  PRECHECK_FAILED
  PROCESSING
  READY_FOR_REVIEW
  PENDING_APPROVAL
  APPROVED
  LOCKED
  RELEASED
  REVERSED
}

enum PayrollCycle {
  MONTHLY
  FIRST_HALF
  SECOND_HALF
  WEEKLY
}

enum PayComponentKind {
  EARNING
  DEDUCTION
  EMPLOYER_COST
}

enum WorkflowStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  CANCELLED
}

enum RequisitionStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  CONVERTED
  CANCELLED
}

enum VacancyStatus {
  DRAFT
  OPEN
  PAUSED
  FILLED
  CLOSED
  CANCELLED
}

enum CandidateStage {
  APPLIED
  SCREENING
  SHORTLISTED
  INTERVIEW
  BACKGROUND_CHECK
  OFFER
  HIRED
  REJECTED
  TALENT_POOL
}

enum OfferStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SENT
  ACCEPTED
  DECLINED
  WITHDRAWN
}

enum OnboardingTaskStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  COMPLETED
  WAIVED
}

enum DocumentTemplateStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model Tenant {
  id             String          @id @default(cuid())
  name           String
  legalName      String?
  country        String          @default("KE")
  status         TenantStatus    @default(ACTIVE)
  subscription   String          @default("starter")
  branding       Json            @default("{}")
  settings       Json            @default("{}")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  users          User[]
  branches       Branch[]
  departments    Department[]
  positions      Position[]
  grades         Grade[]
  costCenters    CostCenter[]
  employees      Employee[]
  leaveTypes     LeaveType[]
  payrollPeriods PayrollPeriod[]
  statutoryRules PayrollStatutoryRule[]
  reportTemplates ReportTemplate[]
  requisitions   Requisition[]
  vacancies      Vacancy[]
  candidates     Candidate[]
  jobOffers      JobOffer[]
  onboardingTasks OnboardingTask[]
  probationReviews ProbationReview[]
  documentTemplates DocumentTemplate[]
  generatedDocuments GeneratedDocument[]
  workflowDefinitions WorkflowDefinition[]
  workflowInstances WorkflowInstance[]
  auditLogs      AuditLog[]
  employeeApprovalRequests EmployeeApprovalRequest[]
}

model User {
  id           String     @id @default(cuid())
  tenantId     String?
  tenant       Tenant?    @relation(fields: [tenantId], references: [id])
  email        String     @unique
  name         String
  passwordHash String
  isActive     Boolean    @default(true)
  mfaEnabled   Boolean    @default(false)
  lastLoginAt  DateTime?
  roles        UserRole[]
  sessions     Session[]
  auditLogs    AuditLog[] @relation("AuditActor")
  requestedEmployeeApprovals EmployeeApprovalRequest[] @relation("EmployeeApprovalRequester")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([tenantId])
}

model EmployeeApprovalRequest {
  id                 String         @id @default(cuid())
  tenantId           String
  tenant             Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requestedByUserId  String?
  requestedByUser    User?          @relation("EmployeeApprovalRequester", fields: [requestedByUserId], references: [id])
  requestedByEmail   String
  requestedByName    String
  approverRole       String
  status             WorkflowStatus @default(SUBMITTED)
  payload            Json
  approvedEmployeeId String?
  decisionComments   String?
  decidedAt          DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([tenantId, status, createdAt])
  @@index([requestedByUserId, createdAt])
}

model Role {
  id          String           @id @default(cuid())
  tenantId    String?
  code        String
  name        String
  description String?
  permissions RolePermission[]
  users       UserRole[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([tenantId, code])
}

model Permission {
  id          String           @id @default(cuid())
  code        String           @unique
  module      String
  action      String
  description String?
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshHash  String
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}

model Branch {
  id        String       @id @default(cuid())
  tenantId  String
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code      String
  name      String
  location  String?
  employees Employee[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([tenantId, code])
}

model Department {
  id        String       @id @default(cuid())
  tenantId  String
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code      String
  name      String
  parentId  String?
  parent    Department?  @relation("DepartmentTree", fields: [parentId], references: [id])
  children  Department[] @relation("DepartmentTree")
  employees Employee[]
  requisitions Requisition[]
  vacancies Vacancy[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([tenantId, code])
}

model Position {
  id        String     @id @default(cuid())
  tenantId  String
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code      String
  title     String
  employees Employee[]
  requisitions Requisition[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([tenantId, code])
}

model Grade {
  id        String     @id @default(cuid())
  tenantId  String
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code      String
  name      String
  employees Employee[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([tenantId, code])
}

model CostCenter {
  id        String     @id @default(cuid())
  tenantId  String
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code      String
  name      String
  employees Employee[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([tenantId, code])
}

model Employee {
  id              String            @id @default(cuid())
  tenantId        String
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employeeNumber  String
  payrollNumber   String?
  legalName       String
  preferredName   String?
  nationalId      String?
  kraPin          String?
  nssfNumber      String?
  shifNumber      String?
  dateOfBirth     DateTime?
  gender          String?
  maritalStatus   String?
  nationality     String?           @default("Kenyan")
  personalEmail   String?
  companyEmail    String?
  phone           String?
  status          EmploymentStatus  @default(ACTIVE)
  hireDate        DateTime
  confirmationDate DateTime?
  contractStart   DateTime?
  contractEnd     DateTime?
  branchId        String?
  branch          Branch?           @relation(fields: [branchId], references: [id])
  departmentId    String?
  department      Department?       @relation(fields: [departmentId], references: [id])
  positionId      String?
  position        Position?         @relation(fields: [positionId], references: [id])
  gradeId         String?
  grade           Grade?            @relation(fields: [gradeId], references: [id])
  costCenterId    String?
  costCenter      CostCenter?       @relation(fields: [costCenterId], references: [id])
  managerId       String?
  manager         Employee?         @relation("ManagerTree", fields: [managerId], references: [id])
  directReports   Employee[]        @relation("ManagerTree")
  bankDetails     EmployeeBankDetail?
  statutory       EmployeeStatutoryDetail?
  documents       EmployeeDocument[]
  salaryHistory   EmployeeSalaryHistory[]
  leaveBalances   LeaveBalance[]
  leaveRequests   LeaveRequest[]
  payrollProfiles PayrollEmployeeProfile[]
  payrollResults  PayrollRunEmployee[]
  onboardingTasks OnboardingTask[]
  probationReviews ProbationReview[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([tenantId, employeeNumber])
  @@unique([tenantId, payrollNumber])
  @@index([tenantId, status])
}

model EmployeeBankDetail {
  id            String   @id @default(cuid())
  employeeId    String   @unique
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  bankName      String
  branchName    String?
  accountNumber String
  paymentMode   String   @default("bank")
  effectiveFrom DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EmployeeStatutoryDetail {
  id                    String   @id @default(cuid())
  employeeId            String   @unique
  employee              Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  payeApplicable        Boolean  @default(true)
  personalRelief        Boolean  @default(true)
  insuranceRelief       Boolean  @default(false)
  shifApplicable        Boolean  @default(true)
  nssfApplicable        Boolean  @default(true)
  housingLevyApplicable Boolean  @default(true)
  pensionApplicable     Boolean  @default(false)
  updatedAt             DateTime @updatedAt
}

model EmployeeDocument {
  id              String   @id @default(cuid())
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  category        String
  name            String
  storageKey      String
  mimeType        String?
  expiresAt       DateTime?
  restricted      Boolean  @default(false)
  version         Int      @default(1)
  retentionPolicy String?
  createdAt       DateTime @default(now())

  @@index([employeeId, category])
}

model EmployeeSalaryHistory {
  id            String   @id @default(cuid())
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  effectiveFrom DateTime
  effectiveTo   DateTime?
  basicSalary   Decimal  @db.Decimal(14, 2)
  currency      String   @default("KES")
  reason        String?
  createdAt     DateTime @default(now())
}

model LeaveType {
  id             String         @id @default(cuid())
  tenantId       String
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code           String
  name           String
  requiresAttachment Boolean    @default(false)
  allowHalfDay   Boolean        @default(true)
  policy         LeavePolicy?
  balances       LeaveBalance[]
  requests       LeaveRequest[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([tenantId, code])
}

model LeavePolicy {
  id                String    @id @default(cuid())
  leaveTypeId        String    @unique
  leaveType          LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  annualEntitlement  Decimal   @db.Decimal(8, 2)
  accrualMethod      String    @default("annual")
  carryForwardCap    Decimal?  @db.Decimal(8, 2)
  allowNegative      Boolean   @default(false)
  prorationRules     Json      @default("{}")
  blackoutRules      Json      @default("{}")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model LeaveBalance {
  id          String    @id @default(cuid())
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId String
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  periodYear  Int
  opening     Decimal   @default(0) @db.Decimal(8, 2)
  accrued     Decimal   @default(0) @db.Decimal(8, 2)
  taken       Decimal   @default(0) @db.Decimal(8, 2)
  adjusted    Decimal   @default(0) @db.Decimal(8, 2)
  closing     Decimal   @default(0) @db.Decimal(8, 2)
  updatedAt   DateTime  @updatedAt

  @@unique([employeeId, leaveTypeId, periodYear])
}

model LeaveRequest {
  id          String         @id @default(cuid())
  employeeId  String
  employee    Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId String
  leaveType   LeaveType      @relation(fields: [leaveTypeId], references: [id])
  startDate   DateTime
  endDate     DateTime
  days        Decimal        @db.Decimal(8, 2)
  reason      String?
  status      WorkflowStatus @default(SUBMITTED)
  approvals   LeaveApproval[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model LeaveApproval {
  id             String         @id @default(cuid())
  leaveRequestId String
  leaveRequest   LeaveRequest   @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)
  approverUserId String
  step           Int
  status         WorkflowStatus @default(SUBMITTED)
  comments       String?
  decidedAt      DateTime?
}

model Requisition {
  id              String            @id @default(cuid())
  tenantId        String
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code            String
  title           String
  departmentId    String?
  department      Department?       @relation(fields: [departmentId], references: [id])
  positionId      String?
  position        Position?         @relation(fields: [positionId], references: [id])
  hiringManagerId String?
  headcount       Int               @default(1)
  budgetedSalaryMin Decimal?        @db.Decimal(14, 2)
  budgetedSalaryMax Decimal?        @db.Decimal(14, 2)
  justification   String
  status          RequisitionStatus @default(DRAFT)
  workflowInstanceId String?
  workflowInstance WorkflowInstance? @relation(fields: [workflowInstanceId], references: [id])
  vacancy         Vacancy?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId, status])
}

model Vacancy {
  id             String         @id @default(cuid())
  tenantId       String
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requisitionId  String?        @unique
  requisition    Requisition?   @relation(fields: [requisitionId], references: [id])
  code           String
  title          String
  departmentId   String?
  department     Department?    @relation(fields: [departmentId], references: [id])
  location       String?
  employmentType String         @default("full_time")
  status         VacancyStatus  @default(DRAFT)
  postingSummary String
  requirements   Json           @default("[]")
  closingDate    DateTime?
  candidates     Candidate[]
  interviews     Interview[]
  offers         JobOffer[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId, status])
}

model Candidate {
  id                String            @id @default(cuid())
  tenantId          String
  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vacancyId         String?
  vacancy           Vacancy?          @relation(fields: [vacancyId], references: [id])
  fullName          String
  email             String
  phone             String?
  source            String?
  stage             CandidateStage    @default(APPLIED)
  salaryExpectation Decimal?          @db.Decimal(14, 2)
  noticePeriod      String?
  screeningScore    Decimal?          @db.Decimal(5, 2)
  notes             String?
  documents         CandidateDocument[]
  interviews        Interview[]
  feedback          InterviewFeedback[]
  offers            JobOffer[]
  onboardingTasks   OnboardingTask[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([tenantId, stage])
  @@index([vacancyId])
}

model CandidateDocument {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  category    String
  name        String
  storageKey  String
  mimeType    String?
  createdAt   DateTime  @default(now())
}

model Interview {
  id             String              @id @default(cuid())
  vacancyId      String
  vacancy        Vacancy             @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  candidateId    String
  candidate      Candidate           @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  interviewType  String
  scheduledAt    DateTime
  panel          Json                @default("[]")
  meetingLink    String?
  status         String              @default("scheduled")
  feedback       InterviewFeedback[]
  createdAt      DateTime            @default(now())

  @@index([vacancyId, scheduledAt])
}

model InterviewFeedback {
  id          String    @id @default(cuid())
  interviewId String
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  reviewerId  String?
  score       Decimal   @db.Decimal(5, 2)
  recommendation String
  comments    String?
  scorecard   Json      @default("{}")
  createdAt   DateTime  @default(now())
}

model JobOffer {
  id              String      @id @default(cuid())
  tenantId        String
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vacancyId       String
  vacancy         Vacancy     @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  candidateId     String
  candidate       Candidate   @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  status          OfferStatus @default(DRAFT)
  offeredSalary   Decimal     @db.Decimal(14, 2)
  currency        String      @default("KES")
  proposedStartDate DateTime?
  benefits        Json        @default("[]")
  workflowInstanceId String?
  workflowInstance WorkflowInstance? @relation(fields: [workflowInstanceId], references: [id])
  generatedDocumentId String?
  generatedDocument GeneratedDocument? @relation(fields: [generatedDocumentId], references: [id])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OnboardingTask {
  id            String               @id @default(cuid())
  tenantId      String
  tenant        Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  candidateId   String?
  candidate     Candidate?           @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  employeeId    String?
  employee      Employee?            @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  ownerRole     String
  title         String
  category      String
  dueDate       DateTime?
  status        OnboardingTaskStatus @default(NOT_STARTED)
  evidenceDocumentId String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([tenantId, status])
  @@index([candidateId])
  @@index([employeeId])
}

model ProbationReview {
  id             String         @id @default(cuid())
  tenantId       String
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employeeId     String
  employee       Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  reviewDate     DateTime
  reviewType     String         @default("probation")
  managerId      String?
  status         WorkflowStatus @default(DRAFT)
  score          Decimal?       @db.Decimal(5, 2)
  recommendation String?
  comments       String?
  workflowInstanceId String?
  workflowInstance WorkflowInstance? @relation(fields: [workflowInstanceId], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([tenantId, status])
  @@index([employeeId, reviewDate])
}

model DocumentTemplate {
  id          String                 @id @default(cuid())
  tenantId    String?
  tenant      Tenant?                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code        String
  name        String
  category    String
  status      DocumentTemplateStatus @default(DRAFT)
  version     Int                    @default(1)
  body        String
  mergeFields Json                   @default("[]")
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  generatedDocuments GeneratedDocument[]

  @@unique([tenantId, code, version])
}

model GeneratedDocument {
  id          String            @id @default(cuid())
  tenantId    String
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  templateId  String
  template    DocumentTemplate  @relation(fields: [templateId], references: [id])
  entityType  String
  entityId    String
  storageKey  String?
  renderedBody String
  status      String            @default("draft")
  createdAt   DateTime          @default(now())
  offers      JobOffer[]
}

model WorkflowDefinition {
  id          String             @id @default(cuid())
  tenantId    String?
  tenant      Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code        String
  name        String
  module      String
  trigger     String
  isActive    Boolean            @default(true)
  steps       Json               @default("[]")
  instances   WorkflowInstance[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([tenantId, code])
}

model WorkflowInstance {
  id           String             @id @default(cuid())
  tenantId     String
  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  definitionId String?
  definition   WorkflowDefinition? @relation(fields: [definitionId], references: [id])
  entityType   String
  entityId     String
  status       WorkflowStatus      @default(SUBMITTED)
  currentStep  Int                 @default(1)
  steps        WorkflowStep[]
  requisitions Requisition[]
  offers       JobOffer[]
  probationReviews ProbationReview[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([tenantId, entityType, entityId])
}

model WorkflowStep {
  id           String           @id @default(cuid())
  instanceId   String
  instance     WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  step         Int
  approverRole String
  approverUserId String?
  status       WorkflowStatus   @default(SUBMITTED)
  comments     String?
  decidedAt    DateTime?

  @@unique([instanceId, step])
}

model PayrollPeriod {
  id          String       @id @default(cuid())
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code        String
  startDate   DateTime
  endDate     DateTime
  payDate     DateTime
  cycle       PayrollCycle @default(MONTHLY)
  isOpen      Boolean      @default(true)
  runs        PayrollRun[]
  createdAt   DateTime     @default(now())

  @@unique([tenantId, code, cycle])
}

model PayrollEmployeeProfile {
  id              String   @id @default(cuid())
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  payGroup        String
  salaryBasis     String   @default("monthly")
  basicSalary     Decimal  @db.Decimal(14, 2)
  currency        String   @default("KES")
  costAllocation  Json     @default("{}")
  glMappings      Json     @default("{}")
  effectiveFrom   DateTime
  effectiveTo     DateTime?
  createdAt       DateTime @default(now())
}

model PayrollRun {
  id             String              @id @default(cuid())
  tenantId       String
  periodId       String
  period         PayrollPeriod       @relation(fields: [periodId], references: [id], onDelete: Cascade)
  status         PayrollRunStatus    @default(DRAFT)
  version        Int                 @default(1)
  payGroup       String
  cycle          PayrollCycle        @default(MONTHLY)
  snapshot       Json                @default("{}")
  precheckResult Json                @default("{}")
  approvedBy     String?
  approvedAt     DateTime?
  lockedAt       DateTime?
  employees      PayrollRunEmployee[]
  inputs         PayrollInput[]
  exports        PayrollExport[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([tenantId, status])
  @@unique([periodId, payGroup, cycle, version])
}

model PayrollInput {
  id          String           @id @default(cuid())
  runId       String
  run         PayrollRun       @relation(fields: [runId], references: [id], onDelete: Cascade)
  employeeId  String?
  code        String
  name        String
  kind        PayComponentKind
  amount      Decimal          @db.Decimal(14, 2)
  taxable     Boolean          @default(true)
  source      String           @default("manual")
  createdAt   DateTime         @default(now())

  @@index([runId, employeeId])
}

model PayrollRunEmployee {
  id                 String     @id @default(cuid())
  runId              String
  run                PayrollRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  employeeId          String
  employee            Employee   @relation(fields: [employeeId], references: [id])
  grossPay            Decimal    @db.Decimal(14, 2)
  taxablePay          Decimal    @db.Decimal(14, 2)
  totalDeductions     Decimal    @db.Decimal(14, 2)
  totalEmployerCosts  Decimal    @db.Decimal(14, 2)
  netPay              Decimal    @db.Decimal(14, 2)
  lines               PayrollResultLine[]
  payslip             PayrollPayslip?
  exceptions          Json       @default("[]")

  @@unique([runId, employeeId])
}

model PayrollResultLine {
  id            String             @id @default(cuid())
  runEmployeeId String
  runEmployee   PayrollRunEmployee @relation(fields: [runEmployeeId], references: [id], onDelete: Cascade)
  code          String
  name          String
  kind          PayComponentKind
  amount        Decimal            @db.Decimal(14, 2)
  metadata      Json               @default("{}")
}

model PayrollPayslip {
  id            String             @id @default(cuid())
  runEmployeeId String             @unique
  runEmployee   PayrollRunEmployee @relation(fields: [runEmployeeId], references: [id], onDelete: Cascade)
  storageKey    String?
  releasedAt    DateTime?
  viewedAt      DateTime?
  payload       Json
}

model PayrollStatutoryRule {
  id             String    @id @default(cuid())
  tenantId        String?
  tenant          Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  country         String
  code            String
  name            String
  effectiveStart  DateTime
  effectiveEnd    DateTime?
  formulaType     String
  employeeRate    Decimal?  @db.Decimal(10, 6)
  employerRate    Decimal?  @db.Decimal(10, 6)
  minimum         Decimal?  @db.Decimal(14, 2)
  maximum         Decimal?  @db.Decimal(14, 2)
  thresholds      Json      @default("[]")
  reliefLogic     Json      @default("{}")
  exportMapping   Json      @default("{}")
  dueDateMetadata Json      @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([tenantId, country, code, effectiveStart])
}

model ReportTemplate {
  id          String   @id @default(cuid())
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code        String
  name        String
  dataset     String
  definition  Json
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, code])
}

model PayrollExport {
  id          String     @id @default(cuid())
  runId       String
  run         PayrollRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  templateId  String?
  format      String
  storageKey  String?
  status      String     @default("queued")
  requestedBy String
  createdAt   DateTime   @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actorUserId String?
  actor       User?    @relation("AuditActor", fields: [actorUserId], references: [id])
  action      String
  entityType  String
  entityId    String?
  before      Json?
  after       Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([tenantId, entityType, entityId])
  @@index([actorUserId, createdAt])
}
